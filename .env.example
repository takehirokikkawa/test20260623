# Copy to .env to override defaults. All values have sensible defaults in docker-compose.yml,
# so `docker compose up --build` works with NO .env file and NO API keys.

POSTGRES_USER=techinsight
POSTGRES_PASSWORD=techinsight
POSTGRES_DB=techinsight

# Host port mappings
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Local embedding model (sentence-transformers). 384-dim. No API key needed.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# CORS origins allowed by the backend
CORS_ORIGINS=http://localhost:3000

# Frontend -> backend base URL (browser-side)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
